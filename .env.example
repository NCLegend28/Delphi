# Delphi configuration — copy to .env and fill in.
# .env is gitignored. .env.example is the documentation.

# --- Required ---
# Bearer token clients must present on every non-public endpoint.
DELPHI_BEARER_TOKEN=replace-with-a-long-random-string

# Ollama server URL on the same VM (or remote).
OLLAMA_BASE_URL=http://localhost:11434

# Absolute path to the Obsidian vault the service will write into.
OBSIDIAN_VAULT_PATH=/home/tali/vault

# Directory for structured JSONL request logs.
LOG_DIR=/var/log/delphi

# Tali is in Dallas.
TIMEZONE=America/Chicago

# --- Optional ---
# Disable the tiny-model classifier; clients must then supply `model`.
CLASSIFY_ENABLED=true

# Disable Obsidian vault writes (useful for benchmarks).
MEMORY_ENABLED=true

# Per-task model tags. The classifier picks a task type; the roster maps
# task type → model tag. To evolve any category: edit the tag here,
# `ollama pull <new>`, restart. `ollama rm <old>` once you're satisfied.
# Per-task sampling options (temperature, etc.) stay in code at
# routing/roster.py:TASK_METADATA — only the model tag is env-driven.
DELPHI_MODEL_CHAT=phi4:14b
DELPHI_MODEL_CODE=qwen2.5-coder:14b
DELPHI_MODEL_REASON=deepseek-r1:14b
DELPHI_MODEL_MULTILINGUAL=gemma3:12b
DELPHI_MODEL_DEEP_CODE=qwen2.5-coder:32b
DELPHI_MODEL_DEEP_REASON=deepseek-r1:32b
DELPHI_MODEL_VAULT_QUERY=phi4:14b
DELPHI_MODEL_CLASSIFIER=phi3.5:3.8b

# How many times an entity must appear before auto-creating its note.
ENTITY_CREATE_THRESHOLD=2

# Uvicorn bind. Namespaced to avoid collision with the generic PORT env var
# that IDEs / Heroku-style platforms commonly inject.
DELPHI_HOST=0.0.0.0
DELPHI_PORT=8080
