# Delphi configuration — copy to .env and fill in.
# .env is gitignored. .env.example is the documentation.

# --- Required ---
# Bearer token clients must present on every non-public endpoint.
DELPHI_BEARER_TOKEN=replace-with-a-long-random-string

# Ollama server URL on the same VM (or remote).
OLLAMA_BASE_URL=http://localhost:11434

# Absolute path to the Obsidian vault the service will write into.
OBSIDIAN_VAULT_PATH=/home/tali/vault

# Directory for structured JSONL request logs.
LOG_DIR=/var/log/delphi

# Tali is in Dallas.
TIMEZONE=America/Chicago

# --- Optional ---
# Disable the tiny-model classifier; clients must then supply `model`.
CLASSIFY_ENABLED=true

# Disable Obsidian vault writes (useful for benchmarks).
MEMORY_ENABLED=true

# Override the classifier model. Ollama tag — `ollama pull phi3.5:3.8b`.
CLASSIFIER_MODEL=phi3.5:3.8b

# Fallback model when classification fails or is disabled and no model is sent.
# Ollama tag — `ollama pull phi4:14b`.
DEFAULT_MODEL=phi4:14b

# How many times an entity must appear before auto-creating its note.
ENTITY_CREATE_THRESHOLD=2

# Uvicorn bind.
HOST=0.0.0.0
PORT=8080
