# Delphi — Docker stack configuration. Copy to .env.docker and fill in.
#   cp .env.docker.example .env.docker
# .env.docker is gitignored and never baked into an image; compose injects it
# at runtime. Only the secrets and host-specific values live here — the
# topology wiring (REDIS_URL, ports, vault path) is set by docker-compose.yml.

# --- Required secrets -------------------------------------------------------
# Long random string. Caddy stamps this onto proxied API calls and the gateway
# verifies it. Generate one: `openssl rand -hex 32`.
DELPHI_BEARER_TOKEN=replace-with-a-long-random-string

# --- Edge / TLS -------------------------------------------------------------
# Default deploy is Tailscale (no domain needed): Caddy serves plain HTTP bound
# to loopback (see docker-compose.yml), and `tailscale serve` fronts it with
# HTTPS on your tailnet. Leave this as ":80" for that path, then on the VPS:
#   sudo tailscale serve --bg --https=443 http://127.0.0.1:80
#   → open https://<machine>.<your-tailnet>.ts.net/
# For a PUBLIC domain instead: set this to the hostname (e.g. delphi.example.com)
# and publish 80/443 publicly in docker-compose.yml — Caddy auto-issues a cert.
DELPHI_DOMAIN=:80

# --- Inference: Ollama Cloud ------------------------------------------------
# This 8 GB box has no GPU, so inference runs on Ollama Cloud. Get a key at
# https://ollama.com (Settings → Keys), then `ollama signin` locally if you
# also want CLI access. The proxy attaches this as a bearer token.
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=

# Tali is in Dallas.
TIMEZONE=America/Chicago

# --- Roster (Ollama Cloud model tags) --------------------------------------
# IMPORTANT: cloud hosts large models under different tags than the local 14B
# roster — there is no tiny phi-3.5 on cloud. Verify each tag exists with
# `ollama run <tag>` or the cloud catalog before relying on it; a missing tag
# only warns at boot but fails the request that needs it.
#
# Sensible cloud starting points (adjust to taste / the current catalog):
DELPHI_MODEL_CHAT=gpt-oss:120b-cloud
DELPHI_MODEL_CODE=qwen3-coder:480b-cloud
DELPHI_MODEL_REASON=deepseek-v3.1:671b-cloud
DELPHI_MODEL_MULTILINGUAL=gpt-oss:120b-cloud
DELPHI_MODEL_DEEP_CODE=qwen3-coder:480b-cloud
DELPHI_MODEL_DEEP_REASON=deepseek-v3.1:671b-cloud
DELPHI_MODEL_VAULT_QUERY=gpt-oss:120b-cloud
# The classifier is now a cloud call too (no tiny local model). gpt-oss:20b is
# the cheapest fast option; or set CLASSIFY_ENABLED=false and have clients send
# `task_type` explicitly (AgentRig and the UI can) to skip classification.
DELPHI_MODEL_CLASSIFIER=gpt-oss:20b-cloud

# --- Behaviour toggles ------------------------------------------------------
CLASSIFY_ENABLED=true
MEMORY_ENABLED=true
ENTITY_CREATE_THRESHOLD=2

# --- Notes on compose-managed vars ------------------------------------------
# These are set for you in docker-compose.yml; you do NOT need them here:
#   WORKER_ENABLED=true            (gateway offloads persist to the worker)
#   REDIS_URL=redis://redis:6379   (internal compose network)
#   OBSIDIAN_VAULT_PATH=/vault     (named volume; sync it with Obsidian Sync,
#                                    git, or syncthing pointed at the volume)
#   LOG_DIR=/var/log/delphi        (named volume)
#   DELPHI_PORT=8080               (internal; Caddy is the public entrypoint)
#   WORKER_METRICS_PORT=9100       (worker Prometheus port, internal only)
