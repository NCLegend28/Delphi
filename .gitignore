# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# uv / venv
.venv/
venv/
env/

# Environment files — never commit real secrets.
.env
.env.*
!.env.example
!.env.docker.example

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editor
.vscode/
.idea/
*.swp
.DS_Store
# macOS AppleDouble metadata — exFAT/external drives litter these everywhere.
._*

# Node / UI build
node_modules/
ui/dist/

# Stray literal "~" dir — guards against an un-expanded OBSIDIAN_VAULT_PATH
# writing into the repo instead of the home dir (see config._expand_user).
/~/

# Runtime artifacts
*.log
/var/log/delphi/
