# Delphi UI — environment variables
#
# Copy this file to .env.local (auto-gitignored via *.local in .gitignore)
# and fill in real values. Vite exposes every VITE_-prefixed variable to
# the browser at import.meta.env.VITE_*.

# Bearer token the UI sends to Delphi as `Authorization: Bearer <token>`.
# Must match DELPHI_BEARER_TOKEN in the backend's .env.
VITE_DELPHI_BEARER_TOKEN=

# Optional: override the backend base URL. Defaults to "" (use Vite proxy
# at /v1, suitable for local dev where the backend is on :8080).
# Set this to a fully-qualified URL for production builds where the UI
# is served from a different origin than the API.
# VITE_DELPHI_BASE_URL=https://delphi.your-tailnet.ts.net

# Optional: where the Vite dev-server proxy forwards /v1, /healthz, /readyz.
# Defaults to http://localhost:8080. Override when the Delphi backend is on
# a different port (e.g. when nginx already owns :8080 locally).
# VITE_DELPHI_PROXY_TARGET=http://localhost:8090
